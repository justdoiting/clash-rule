mixed-port: 7890
tcp-concurrent: true
allow-lan: true
ipv6: true
log-level: info
unified-delay: true
find-process-mode: strict

dns:
  enable: true
  ipv6: false
  prefer-h3: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter: ['+.lan', '+.local', 'rule-set:CNSITE']
  listen: 0.0.0.0:1053
  default-nameserver: [119.29.29.29, 223.5.5.5]
  nameserver: [119.29.29.29, 52.80.66.66, 1.2.4.8]
  nameserver-policy:
    'rule-set:CNPro': [119.29.29.29, 180.184.2.2, 101.226.4.6]
    'rule-set:Proxy': [1.1.1.1, 8.8.8.8, 64.6.64.6, 94.140.14.140]

sniffer: { enable: true, sniff: { HTTP: { ports: [80], override-destination: true }, TLS: { ports: [443, 8443] }, QUIC: { ports: [443, 8443] } } }

tun:
  enable: true
  stack: mixed
  device: utun
  endpoint-independent-nat: true
  auto-route: false
  auto-detect-interface: false
  auto-redirect: false
  strict-route: false

profile:
  store-selected: true
  store-fake-ip: true
 
